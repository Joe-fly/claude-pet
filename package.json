{
  "name": "claude-pet",
  "version": "1.0.0",
  "description": "Claude Code Desktop Pet - Pixel Art Animation",
  "main": "electron/main.js",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder"
  },
  "keywords": [
    "electron",
    "desktop-pet",
    "claude",
    "pixel-art"
  ],
  "author": "Lary",
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "flask": "^0.2.10",
    "node-pty": "^1.1.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "build": {
    "appId": "com.claude.pet",
    "productName": "ClaudePet",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.entertainment"
    }
  }
}
